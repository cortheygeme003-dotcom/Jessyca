import os
import subprocess

def abrir_programa(programa):
    import os
    import subprocess
    import speech_recognition as sr

    def abrir_programa(programa):
        try:
            subprocess.Popen(programa)
            print(f"Abriendo {programa}...")
        except Exception as e:
            print(f"Error al abrir {programa}: {e}")


    def listar_archivos(directorio="."):
        try:
            archivos = os.listdir(directorio)
            print(f"Archivos en {directorio}:")
            for archivo in archivos:
                print(archivo)
        except Exception as e:
            print(f"Error al listar archivos: {e}")


    def escuchar_comando():
        recognizer = sr.Recognizer()
        with sr.Microphone() as source:
            print("Escuchando...")
            audio = recognizer.listen(source)
        try:
            comando = recognizer.recognize_google(audio, language="es-ES")
            print(f"Tú dijiste: {comando}")
            return comando
        except sr.UnknownValueError:
            print("No pude entender lo que dijiste.")
        except sr.RequestError as e:
            print(f"Error con el servicio de reconocimiento; {e}")


    if __name__ == "__main__":
        # Uso de ejemplo: abrir el Bloc de notas y listar archivos
        try:
            abrir_programa("notepad.exe")
        except Exception:
            pass
        listar_archivos()
        # Escuchar un comando de voz (requiere micrófono y dependencias instaladas)
        try:
            comando = escuchar_comando()
        except Exception as e:
            print(f"No se pudo usar el reconocimiento de voz: {e}")
